# Public site URL (no trailing slash). Used for metadata, sitemap, and OG tags.
SITE_URL=http://localhost:3000

# Google Analytics 4 measurement ID (optional until production)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Microsoft Clarity project ID (optional)
# NEXT_PUBLIC_CLARITY_PROJECT_ID=xxxxxxxxxx

# Vercel Web Analytics — set to true only when enabled in Vercel project settings
# NEXT_PUBLIC_VERCEL_ANALYTICS_ENABLED=true

# Contact form — Telegram (recommended) or Resend
# TELEGRAM_BOT_TOKEN=          # exact name required (not TELEGRAM_BOT_TOKE)
# TELEGRAM_CONTACT_CHAT_ID=     # your numeric chat id; send /start to the bot first

# Contact form / Resend (alternative)
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=timaiskandarov5@gmail.com
# CONTACT_FROM_EMAIL=Codev_Tim <noreply@yourdomain.com>
